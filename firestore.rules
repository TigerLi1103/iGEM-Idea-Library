rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "lichengxi1103@gmail.com");
    }

    function isValidIdea(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.summary is string && data.summary.size() < 1000 &&
             data.description is string && data.description.size() < 10000 &&
             data.status in ['draft', 'pending', 'published', 'featured'];
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
    }

    match /ideas/{ideaId} {
      // Anyone can read published ideas. Authors and admins can read any.
      allow read: if resource.data.status == 'published' || 
                     isOwner(resource.data.authorId) || 
                     isAdmin();
      
      allow create: if isAuthenticated() && 
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.status == 'pending' &&
                       isValidIdea(request.resource.data);
      
      allow update: if isAuthenticated() && (
        // Admin can approve (change status to published)
        (isAdmin() && isValidIdea(request.resource.data)) ||
        // Owner can edit but not publish
        (isOwner(resource.data.authorId) && 
         request.resource.data.authorId == resource.data.authorId &&
         (request.resource.data.status == 'pending' || request.resource.data.status == 'draft') &&
         isValidIdea(request.resource.data))
      );
      
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /villages/{villageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
